{
  "name": "builtin.codex-monorepo",
  "version": "0.0.0-dev",
  "description": "Codex extension monorepo for Lvce Editor",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:extension": "node packages/build/src/build-extension.ts",
    "build:static": "node scripts/build-static.ts",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --format=esm --bundle --external:electron --external:node:* --watch packages/extension/src/codexMain.ts --outfile=packages/extension/dist/codexMain.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "install:extension": "node packages/build/src/install-extension.ts",
    "lint": "eslint . && prettier --check .",
    "test": "npm test --workspaces --if-present",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc -b"
  },
  "author": "Lvce Editor",
  "license": "MIT",
  "devDependencies": {
    "@lvce-editor/eslint-config": "^17.3.1",
    "eslint": "^10.7.0",
    "prettier": "^4.0.0-alpha.10",
    "typescript": "^6.0.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  }
}
