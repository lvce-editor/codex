{
  "name": "builtin.codex",
  "version": "0.0.0-dev",
  "description": "Codex integration for Lvce Editor",
  "main": "dist/codexMain.js",
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "author": "Lvce Editor",
  "license": "MIT",
  "type": "module",
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "devDependencies": {
    "@lvce-editor/api": "^8.54.0",
    "@lvce-editor/virtual-dom-worker": "^11.8.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.12"
  }
}
