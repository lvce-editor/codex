{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "composite": true,
    "isolatedModules": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "strict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "target": "ESNext",
    "types": ["node"]
  },
  "include": ["src", "test"]
}
